{
  "headers": [
    {
      "source": "/api/admin-chat",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/scheduled-reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/admin-ai-auto",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/bouncie-sync",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/maintenance-alerts",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/missed-maintenance",
      "schedule": "0 * * * *"
    }
  ]
}
