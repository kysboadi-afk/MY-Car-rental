{
  "functions": {
    "api/admin-chat.js":                    { "maxDuration": 60 },
    "api/stripe-reconcile.js":              { "maxDuration": 60 },
    "api/stripe-backfill.js":              { "maxDuration": 60 },
    "api/stripe-replay.js":               { "maxDuration": 60 },
    "api/send-reservation-email.js":        { "maxDuration": 60 },
    "api/stripe-webhook.js":                { "maxDuration": 60 },
    "api/store-booking-docs.js":            { "maxDuration": 20 },
    "api/bouncie-sync.js":                  { "maxDuration": 30 },
    "api/bouncie-webhook.js":               { "maxDuration": 20 },
    "api/bouncie-location.js":              { "maxDuration": 20 },
    "api/v2-mileage.js":                    { "maxDuration": 20 },
    "api/send-extension-confirmation.js":   { "maxDuration": 25 },
    "api/admin-resend-extension.js":        { "maxDuration": 25 },
    "api/v2-customers.js":                  { "maxDuration": 25 },
    "api/revenue-self-heal.js":             { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/scheduled-reminders",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/admin-ai-auto",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/bouncie-sync",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/maintenance-alerts",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/missed-maintenance",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/revenue-self-heal",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cleanup-blocked-dates",
      "schedule": "0 2 * * *"
    }
  ]
}
