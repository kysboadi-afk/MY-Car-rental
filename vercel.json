{
  "headers": [
    {
      "source": "/api/admin-chat",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "https://www.slytrans.com" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    },
    {
      "source": "/api/tts",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "https://www.slytrans.com" },
        { "key": "Access-Control-Allow-Methods", "value": "POST, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ],
  "functions": {
    "api/tts.js":                           { "maxDuration": 30 },
    "api/admin-chat.js":                    { "maxDuration": 60 },
    "api/sms-webhook.js":                   { "maxDuration": 30 },
    "api/bouncie-sync-cron.js":             { "maxDuration": 30 },
    "api/oil-check-cron.js":               { "maxDuration": 60 },
    "api/stripe-reconcile.js":              { "maxDuration": 60 },
    "api/stripe-reconcile-cron.js":         { "maxDuration": 60 },
    "api/stripe-backfill.js":              { "maxDuration": 60 },
    "api/stripe-replay.js":               { "maxDuration": 60 },
    "api/send-reservation-email.js":        { "maxDuration": 60 },
    "api/stripe-webhook.js":                { "maxDuration": 60 },
    "api/store-booking-docs.js":            { "maxDuration": 20 },
    "api/bouncie-sync.js":                  { "maxDuration": 30 },
    "api/bouncie-webhook.js":               { "maxDuration": 20 },
    "api/bouncie-location.js":              { "maxDuration": 20 },
    "api/v2-mileage.js":                    { "maxDuration": 20 },
    "api/send-extension-confirmation.js":   { "maxDuration": 25 },
    "api/admin-resend-extension.js":        { "maxDuration": 25 },
    "api/admin-resend-booking.js":          { "maxDuration": 30 },
    "api/v2-customers.js":                  { "maxDuration": 25 },
    "api/revenue-self-heal.js":             { "maxDuration": 60 },
    "api/v2-system-health.js":              { "maxDuration": 30 },
    "api/system-health-fix-sms.js":         { "maxDuration": 30 },
    "api/system-health-fix-availability.js": { "maxDuration": 30 },
    "api/scheduled-reminders.js":            { "maxDuration": 60 }
