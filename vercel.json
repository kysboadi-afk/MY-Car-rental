  "crons": [
    {
      "path": "/api/scheduled-reminders",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/admin-ai-auto",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/bouncie-sync",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/maintenance-alerts",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/missed-maintenance",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/revenue-self-heal",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cleanup-blocked-dates",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/v2-system-health",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/bouncie-sync-cron",
      "schedule": "0 8,20 * * *"
    },
    {
      "path": "/api/oil-check-cron",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/stripe-reconcile-cron",
      "schedule": "0 */8 * * *"
    }
  ]
}
