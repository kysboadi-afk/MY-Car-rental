# .env.staging.example
# ---------------------------------------------------------------------------
# Staging environment variable checklist for the sly-rides-staging Vercel
# project.  Copy this file to .env.local for local development against the
# staging Supabase instance, or use it as a reference when adding variables
# in Vercel → Settings → Environment Variables.
#
# ⚠️  Never commit real secrets.  This file contains placeholder values only.
# ⚠️  Set these in the STAGING Vercel project — not in the production project.
# ---------------------------------------------------------------------------

# ── Supabase (staging project) ───────────────────────────────────────────────
SUPABASE_URL=https://<your-staging-ref>.supabase.co
SUPABASE_ANON_KEY=<staging-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<staging-service-role-key>

# ── Admin portal ─────────────────────────────────────────────────────────────
ADMIN_SECRET=<choose-a-staging-only-admin-password>

# ── Stripe (test-mode keys — start with sk_test_ / pk_test_) ─────────────────
STRIPE_SECRET_KEY=sk_test_<your-test-secret-key>
STRIPE_PUBLISHABLE_KEY=pk_test_<your-test-publishable-key>
# Signing secret for the staging webhook endpoint (whsec_...)
# Created in Stripe Dashboard → Test Mode → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_<staging-webhook-signing-secret>

# ── Phone OTP ────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
OTP_SECRET=<64-char-random-hex-string>

# ── Cron protection ──────────────────────────────────────────────────────────
# Any random string — sent as the Authorization header for cron-gated routes
CRON_SECRET=<random-string>

# ── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<staging-sender-email@example.com>
SMTP_PASS=<gmail-app-password-or-smtp-password>
OWNER_EMAIL=<where-staging-booking-alerts-go@example.com>

# ── SMS / TextMagic ──────────────────────────────────────────────────────────
TEXTMAGIC_USERNAME=<textmagic-account-username>
TEXTMAGIC_API_KEY=<textmagic-api-key>
# Optional — custom SMS sender ID or number
# TEXTMAGIC_FROM=

# ── SignNow e-signature ───────────────────────────────────────────────────────
SIGNNOW_TEMPLATE_ID=<signnow-template-id>
# OAuth credentials (recommended — static tokens expire in ~30-60 min)
SIGNNOW_CLIENT_ID=<signnow-client-id>
SIGNNOW_CLIENT_SECRET=<signnow-client-secret>
SIGNNOW_EMAIL=<signnow-account-email>
SIGNNOW_PASSWORD=<signnow-account-password>
# Optional — set only if your template role is not "Signer 1"
# SIGNNOW_ROLE_NAME=Signer 1

# ── GitHub calendar blocking ──────────────────────────────────────────────────
# Fine-grained PAT with Contents: Read and write on kysboadi-afk/SLY-RIDES
# Omit (or leave blank) if you do not want staging bookings to write to
# the live booked-dates.json file.
GITHUB_TOKEN=github_pat_<your-pat>
# Optional — defaults to kysboadi-afk/SLY-RIDES
# GITHUB_REPO=kysboadi-afk/SLY-RIDES

# ── AI Assistant ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-<your-openai-api-key>

# ── Auto-set by Vercel — DO NOT set manually ─────────────────────────────────
# VERCEL_URL  (set automatically by Vercel on every deployment)
